# Local-only defaults for Spark Platform v0. Do not reuse in shared environments.
PROJECT_NAME=spark-plat-v0

SPARK_VERSION=4.1.2
SPARK_BASE_IMAGE=apache/spark:4.1.2-scala2.13-java17-python3-ubuntu
SPARK_RUNTIME_IMAGE=spark-plat-v0-spark:4.1.2
SPARK_HISTORY_IMAGE=spark-plat-v0-spark-history:4.1.2
SPARK_WORKER_CORES=1
SPARK_WORKER_MEMORY=1g
SPARK_PLAT_CONFIG_ENV=local

LOADER_IMAGE=spark-plat-v0-eventlog-loader:go1.26
GO_BASE_IMAGE=golang:1.26-bookworm

MINIO_BASE_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z-cpuv1
MINIO_MC_BASE_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z-cpuv1
MINIO_IMAGE=spark-plat-v0-minio:2025-09-07
MINIO_MC_IMAGE=spark-plat-v0-minio-mc:2025-08-13
MINIO_ROOT_USER=spv0minio
MINIO_ROOT_PASSWORD=spv0minio123
MINIO_LAKEHOUSE_BUCKET=lakehouse
MINIO_LOG_BUCKET=spark-logs

CLICKHOUSE_BASE_IMAGE=clickhouse:26.5.1-jammy
CLICKHOUSE_IMAGE=spark-plat-v0-clickhouse:26.5.1
CLICKHOUSE_DB=spark_observability
CLICKHOUSE_USER=spv0
CLICKHOUSE_PASSWORD=spv0clickhouse123

MINIO_API_PORT=29000
MINIO_CONSOLE_PORT=29001
SPARK_MASTER_UI_PORT=28081
SPARK_HISTORY_UI_PORT=28080
CLICKHOUSE_HTTP_PORT=28123
CLICKHOUSE_NATIVE_PORT=29002
